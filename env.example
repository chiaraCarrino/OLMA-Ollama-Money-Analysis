# URL di Ollama.
# Lascia il valore di default se usi: docker-compose --profile with-ollama up
# Cambia con http://host.docker.internal:11434/api/generate
# se hai Ollama installato sul tuo PC e vuoi usarlo senza il container Docker.

OLLAMA_URL=http://ollama:11434/api/generate
