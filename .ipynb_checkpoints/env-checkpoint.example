# ─────────────────────────────────────────────────────────────
# OLMA — variabili d'ambiente
# ─────────────────────────────────────────────────────────────
# Copia questo file e rinominalo in .env nella stessa cartella.
# Il file .env NON viene caricato su GitHub (.gitignore lo esclude).
# ─────────────────────────────────────────────────────────────

# URL di Ollama.
# Lascia il valore di default se usi: docker-compose --profile with-ollama up
# Cambia con http://host.docker.internal:11434/api/generate
# se hai Ollama installato sul tuo PC e vuoi usarlo senza il container Docker.

# URL per l'agente di classificazione (enrich.py)
OLLAMA_URL=http://host.docker.internal:11434/api/generate

# URL per l'agente chat (chat_agent.py)
OLLAMA_CHAT_URL=http://host.docker.internal:11434/api/chat

# Modello per la classificazione (task semplice, modello leggero)
OLLAMA_MODEL=llama3.2

# Modello per la chat (tool calling, serve un modello più capace)
OLLAMA_CHAT_MODEL=qwen2.5:14b
